# Spotify API credentials - get from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
SPOTIFY_REDIRECT_URI=http://localhost:5000/callback

# Flask secret key - generate a secure random string
SECRET_KEY=your_very_secret_flask_key_here

# PostgreSQL database URL
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://postgres:password@localhost:5432/spotify_game

# Flask environment
FLASK_ENV=development
FLASK_DEBUG=1
